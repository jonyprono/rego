generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  password  String
  role      String   @default("TECHNICIAN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}

model Report {
  id               Int      @id @default(autoincrement())
  reportNumber     String   @unique
  date             DateTime
  interventionType String
  startTime        String
  endTime          String
  duration         Float
  price            Float?
  quarter          String?

  // Client details
  clientName       String
  agencyName       String
  clientAddress    String
  clientDepartment String

  // Observations
  problemsEncountered String? @db.Text
  situationBefore     String? @db.Text
  solutionProvided    String? @db.Text
  situationAfter      String? @db.Text
  remarks             String? @db.Text

  // Validation
  clientRepresentative String?
  representativeRole   String?
  validationDate       DateTime?
  clientSignature      String?   @db.Text // Base64 string or file path

  technicians Technician[]
  photos      Photo[]

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Technician {
  id       Int    @id @default(autoincrement())
  fullName String
  techId   String
  reportId Int
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Photo {
  id         Int      @id @default(autoincrement())
  url        String
  type       String // "presence" or "intervention"
  reportId   Int
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  uploadedAt DateTime @default(now())
}
